G MACINTEL64 ../_/_svm_getenv_MACINTEL64.plugin _svm_getenv.plugin
G MACINTEL64 ../_/_svm_setenv_MACINTEL64.plugin _svm_setenv.plugin
G MACINTEL64 ../_/_svmachines_MACINTEL64.plugin _svmachines.plugin
G MACINTEL64 ../_/_svmlight_MACINTEL64.plugin _svmlight.plugin
G MACINTEL64 ../l/libsvm_MACINTEL64.dylib libsvm.dylib
G MACARM64 ../_/_svm_dlopenable_MACARM64.plugin _svm_dlopenable.plugin
G MACARM64 ../_/_svm_getenv_MACARM64.plugin _svm_getenv.plugin
G MACARM64 ../_/_svm_setenv_MACARM64.plugin _svm_setenv.plugin
G MACARM64 ../_/_svmachines_MACARM64.plugin _svmachines.plugin
G MACARM64 ../_/_svmlight_MACARM64.plugin _svmlight.plugin
G MACARM64 ../l/libsvm_MACARM64.dylib libsvm.dylib
G WIN64 ../_/_svm_dlopenable_WIN64A.plugin _svm_dlopenable.plugin
G WIN64 ../_/_svm_getenv_WIN64A.plugin _svm_getenv.plugin
G WIN64 ../_/_svm_setenv_WIN64A.plugin _svm_setenv.plugin
G WIN64 ../_/_svmachines_WIN64A.plugin _svmachines.plugin
G WIN64 ../_/_svmlight_WIN64A.plugin _svmlight.plugin
G WIN64 ../l/libsvm_WIN64A.dll libsvm.dll
G WIN64A ../_/_svm_dlopenable_WIN64A.plugin _svm_dlopenable.plugin
G WIN64A ../_/_svm_getenv_WIN64A.plugin _svm_getenv.plugin
G WIN64A ../_/_svm_setenv_WIN64A.plugin _svm_setenv.plugin
G WIN64A ../_/_svmachines_WIN64A.plugin _svmachines.plugin
G WIN64A ../_/_svmlight_WIN64A.plugin _svmlight.plugin
G WIN64A ../l/libsvm_WIN64A.dll libsvm.dll
