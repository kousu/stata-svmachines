. desc P*

              storage   display    value
variable name   type    format     label      variable label
-----------------------------------------------------------------------------------------------------------------------
P               byte    %8.0g      origin     Predicted Car type
P_Domestic_Bu~k double  %10.0g                P svm score Domestic vs Buick
P_Domestic_Do~e double  %10.0g                P svm score Domestic vs Dodge
P_Domestic_Fo~n double  %10.0g                P svm score Domestic vs Foreign
P_Buick_Dodge   double  %10.0g                P svm score Buick vs Dodge
P_Buick_Foreign double  %10.0g                P svm score Buick vs Foreign
P_Dodge_Foreign double  %10.0g                P svm score Dodge vs Foreign

. ereturn list

scalars:
                  e(N) =  69
            e(N_class) =  4
               e(N_SV) =  69

macros:
             e(levels) : "0 3 2 1"
             e(depvar) : "foreign"
         e(svm_kernel) : "RBF"
           e(svm_type) : "SVC"
              e(model) : "svmachines"
              e(title) : "Support Vector Machine"
              e(estat) : "svm_estat"
            e(predict) : "svm_predict"
            e(cmdline) : "svmachines foreign price mpg rep78 headroom trunk weight length turn displacement gear_ra.."
                e(cmd) : "svmachines"

matrices:
                e(rho) :  4 x 4
            e(sv_coef) :  3 x 69

